class Solution(object):
    def averageValue(self, nums):
        result=0
        count = 0
        for num in nums:
            if num % 2 == 0 and num % 3 == 0:
                result += num 
                count+=1
        if count == 0:
            return 0
        return result/count
        """
        :type nums: List[int]
        :rtype: int
        """
        
